# Copy this file to .env and fill in real values.

# AI provider keys. Configure at least one.
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Email sender.
# Gmail users usually need an app password.
EMAIL_ADDRESS=yourname@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Multiple recipients are supported with comma, semicolon, or newline separators.
EMAIL_TO=yourname@gmail.com,colleague@qq.com,lab@163.com
# EMAIL_RECIPIENTS=friend@outlook.com;team@163.com

# Send one email per recipient instead of one grouped email.
EMAIL_SEND_INDIVIDUALLY=false

# Optional SMTP settings. Defaults are Gmail over SSL.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465

# Blog publishing into the Astro/Decap papers collection.
BLOG_PUBLISH_ENABLED=true
# Defaults to the parent folder of ai-digest-main.
BLOG_ROOT=..
# Optional explicit target. If set, it wins over BLOG_ROOT.
# BLOG_PAPERS_DIR=../src/content/papers
BLOG_DAILY_DIGEST_TAG=每日摘要
# Optional cover image for the generated papers entry.
# BLOG_COVER=/assets/knowledge-hero.png
# Admin URL used only for log output.
BLOG_ADMIN_URL=http://127.0.0.1:4321/admin/#/collections/papers/new
