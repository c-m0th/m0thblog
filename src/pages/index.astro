---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import EntryCard from "../components/EntryCard.astro";
import { collectionInfo, isPublished, sortByDate } from "../lib/content";

const notes = sortByDate((await getCollection("notes")).filter(isPublished));
const papers = sortByDate((await getCollection("papers")).filter(isPublished));
const projects = sortByDate((await getCollection("projects")).filter(isPublished));

const latest = [
  ...notes.map((entry) => ({ entry, collection: "notes" as const })),
  ...papers.map((entry) => ({ entry, collection: "papers" as const })),
  ...projects.map((entry) => ({ entry, collection: "projects" as const }))
].sort((a, b) => b.entry.data.date.valueOf() - a.entry.data.date.valueOf()).slice(0, 6);
---

<BaseLayout>
  <section class="hero container">
    <div class="hero__copy">
      <p class="eyebrow">Personal Knowledge System</p>
      <h1>知识雷达</h1>
      <p class="hero__lead">
        把学过的知识、读过的论文和做过的项目整理成可以持续生长的个人知识库。
      </p>
      <div class="hero__actions">
        <a class="button" href="/search/">搜索内容</a>
        <a class="button button--ghost" href="/papers/">浏览论文</a>
      </div>
    </div>
    <div class="hero__media">
      <img src="/assets/knowledge-hero.png" alt="桌面上的笔记、论文和电脑" />
    </div>
  </section>

  <section class="section container" aria-label="内容统计">
    <div class="metrics">
      <div class="metric">
        <strong>{notes.length}</strong>
        <span>学习笔记</span>
      </div>
      <div class="metric">
        <strong>{papers.length}</strong>
        <span>论文阅读</span>
      </div>
      <div class="metric">
        <strong>{projects.length}</strong>
        <span>项目复盘</span>
      </div>
    </div>
  </section>

  <section class="section container">
    <div class="section-title">
      <div>
        <h2>分类入口</h2>
        <p>按内容类型进入，后续可以继续扩展专题、时间线和研究方向。</p>
      </div>
    </div>
    <div class="collection-grid">
      {
        Object.values(collectionInfo).map((item) => (
          <a class="collection-link" href={item.href}>
            <strong>{item.label}</strong>
            <p>{item.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="section container">
    <div class="section-title">
      <div>
        <h2>最近更新</h2>
        <p>所有笔记、论文和项目会按日期混合排序，方便回到最新上下文。</p>
      </div>
      <a class="text-link" href="/search/">查找更多</a>
    </div>
    <div class="entry-grid">
      {latest.map(({ entry, collection }) => <EntryCard entry={entry} collection={collection} />)}
    </div>
  </section>
</BaseLayout>
